# devx.yaml
# Example topology configuration for running multiple interconnected services
# locally and exposing them through a single devx Cloudflare tunnel.
#
# Run 'devx up' in the same directory as this file to provision dependencies 
# and expose services.

# Project name determines the base subdomain for all nested services below.
# E.g. If your dev name is 'james', the base domain is 'james-prj-demo-app'
name: demo-app

# Optional: Override the fallback `.ipv1337.dev` domain with your own custom domain (BYOD).
# Ensure you are logged into a Cloudflare account that has permissions over this zone.
domain: mycompany.dev

# Define remote and local secret vaults to securely inject environment variables 
# directly into your `devx shell` without writing plaintext .env files to disk.
env:
  - 1password://dev/my-app/env
  - gcp://projects/my-org/secrets/my-prod/versions/latest
  - bitwarden://my-app-env
  - file://.env.local

# Define local databases to provision. When running 'devx up', devx will 
# spin up containers with persistent volumes for each defined database.
databases:
  # Supported engines: postgres, redis, mysql, mongo
  - engine: postgres
    port: 5432
    # You can configure a one-click fetch of a staging/scrubbed database
    # via `devx db pull postgres`. The standard output of this command
    # is streamed directly into the local container.
    pull:
      command: "gcloud storage cat gs://my-company-scrubbed-dumps/nightly.sql.gz | gunzip"
  - engine: redis

tunnels:
  # The 'name' field defines the subdomain for this specific service.
  # Example output: https://api-demo-app-james.ipv1337.dev
  - name: api
    port: 8080
    
    # You can instantly secure any application from the public edge by providing
    # basic authentication credentials. No external premium services necessary.
    basic_auth: "admin:supersecret"

  # Example output: https://web-demo-app-james.ipv1337.dev
  - name: web
    port: 3000

    # You can simulate poor network conditions to test your frontend.
    # Supported profiles: '3g', 'edge', 'slow'
    throttle: "3g"

  # Example output: https://webhooks-demo-app-james.ipv1337.dev
  - name: webhooks
    port: 8000
