# devx secrets — copy this file to .env and fill in your values.
# Never commit .env to git.
#
# Get CF_TUNNEL_TOKEN with:
#   cloudflared login
#   cloudflared tunnel create dev-tunnel-<your-name>
#   cloudflared tunnel token dev-tunnel-<your-name>

CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
DEV_HOSTNAME=your-name-dev-machine
