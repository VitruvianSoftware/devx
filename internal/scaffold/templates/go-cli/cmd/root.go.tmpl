package cmd

import (
	"fmt"

	"github.com/spf13/cobra"
)

var version = "dev"

var rootCmd = &cobra.Command{
	Use:     "{{.ProjectName}}",
	Short:   "{{.Description}}",
	Version: version,
	RunE: func(cmd *cobra.Command, args []string) error {
		return cmd.Help()
	},
	SilenceErrors: true,
	SilenceUsage:  true,
}

func Execute() error {
	return rootCmd.Execute()
}

func init() {
	// Add subcommands here:
	// rootCmd.AddCommand(mySubCmd)
	_ = fmt.Sprintf // keep import
}
