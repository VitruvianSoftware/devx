version: 2
builds:
  - id: {{.ProjectName}}
    main: .
    binary: {{.ProjectName}}
    env: [CGO_ENABLED=0]
    goos: [darwin, linux, windows]
    goarch: [amd64, arm64]
    ldflags:
      - -s -w
      - -X {{.ModulePath}}/cmd.version={{"{{"}}{{".Version"}}{{"}}"}}

archives:
  - format: tar.gz
    name_template: "{{.ProjectName}}_{{ `{{` }} .Os {{ `}}` }}_{{ `{{` }} .Arch {{ `}}` }}"

checksum:
  name_template: checksums.txt

release:
  draft: false
